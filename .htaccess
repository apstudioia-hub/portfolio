# ============================================
# Portfolio Aurélien POTOLA — Configuration Apache
# Sécurité maximale pour hébergement classique
# ============================================

# === Forcer HTTPS ===
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  # Forcer le www (optionnel — décommenter si besoin)
  # RewriteCond %{HTTP_HOST} ^([^.]+\.[^.]+)$ [NC]
  # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [L,R=301]
</IfModule>

# === Headers de sécurité ===
<IfModule mod_headers.c>
  # HSTS — force HTTPS pendant 1 an
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Protection clickjacking
  Header always set X-Frame-Options "DENY"

  # Empêche le MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Référence : ne pas envoyer l'URL complète aux sites externes
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions APIs (les bloquer toutes par défaut)
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), interest-cohort=()"

  # CSP — Content Security Policy
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self'; form-action 'self' mailto:; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"

  # Cross-Origin policies
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"

  # Cache & sécurité fichiers sensibles
  <FilesMatch "\.(htaccess|htpasswd|env|log|git)$">
    Header always set X-Content-Type-Options "nosniff"
    Require all denied
  </FilesMatch>

  # Cache long pour les assets statiques
  <FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|svg|woff2|woff|ttf|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Cache plus court pour HTML
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# === Compression GZIP ===
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# === Bloquer accès aux fichiers sensibles ===
<FilesMatch "^(\.htaccess|\.htpasswd|\.git|\.env|\.DS_Store|\.gitignore|package\.json|package-lock\.json|composer\.json|composer\.lock|README\.md|LICENSE|node_modules)">
  Require all denied
</FilesMatch>

# === Empêcher le directory listing ===
Options -Indexes -MultiViews

# === Protection contre hotlinking d'images ===
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?potola(\.[a-z]+)?($|/) [NC]
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?linkedin\.com [NC]
  RewriteCond %{HTTP_REFERER} !^https?://localhost [NC]
  RewriteRule \.(jpg|jpeg|png|gif|webp)$ - [F,NC,L]
</IfModule>

# === Types MIME corrects ===
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType video/mp4 .mp4
  AddType video/quicktime .mov
  AddType application/pdf .pdf
  AddType font/woff2 .woff2
</IfModule>

# === Page d'erreur custom (optionnel) ===
ErrorDocument 404 /index.html

# === Désactiver les méthodes HTTP non utilisées ===
<LimitExcept GET POST HEAD OPTIONS>
  Require all denied
</LimitExcept>
